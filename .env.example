# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080

# ── Database ───────────────────────────────────────────────────────────────────
# Docker Compose maps postgres to host port 5433
DB_HOST=localhost
DB_PORT=5433
DB_USER=atmos
DB_PASSWORD=atmos
DB_NAME=atmos_dev
DB_SSLMODE=disable
DB_MAX_OPEN=25
DB_MAX_IDLE=10
DB_MAX_LIFE=5m

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── Google OAuth (optional — leave blank to disable) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
# Gmail OAuth callback — must match the redirect URI registered in Google Cloud Console
GOOGLE_GMAIL_REDIRECT_URL=http://localhost:8080/api/v1/gmail/callback

# ── Internal endpoints ─────────────────────────────────────────────────────────
# Shared secret for /internal/* endpoints (e.g. cron-triggered sync-all).
# Generate with: openssl rand -hex 32
INTERNAL_SYNC_KEY=

# ── AWS SES (email sending) ────────────────────────────────────────────────────
# Region where your SES identity is verified.
# On EC2, auth uses the IAM instance role automatically — no keys needed.
# For local dev, set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
AWS_REGION=ap-south-1
SES_FROM_ADDRESS=Atmos <noreply@atmosapp.dev>

# ── Logging ────────────────────────────────────────────────────────────────────
# development → pretty console output
# production  → structured JSON
LOG_LEVEL=info
